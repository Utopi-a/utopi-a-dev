{
  "name": "utopi-a-dev",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "doppler run -- next dev --turbopack",
    "build": "next build",
    "build:local": "doppler run -- next build",
    "start": "next start",
    "start:local": "doppler run -- next start",
    "env:setup": "doppler setup --no-interactive",
    "env:open": "doppler open dashboard",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "prepare": "lefthook install",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "db:generate": "doppler run -- drizzle-kit generate",
    "db:migrate": "doppler run -- drizzle-kit migrate",
    "db:studio": "doppler run -- drizzle-kit studio",
    "scrape:shooting-ranges": "pnpm dlx tsx src/features/ammo-ledger/range-seed/scrape-shajoukyo-ranges/scrape-shajoukyo-ranges.ts",
    "scrape:sportsgun-ranges": "pnpm dlx tsx src/features/ammo-ledger/range-seed/scrape-sportsgun-ranges/scrape-sportsgun-ranges.ts",
    "scrape:gun-shops": "pnpm dlx tsx src/features/ammo-ledger/counterparty-seed/scrape-nikkaren-traders/scrape-nikkaren-traders.ts",
    "resolve:shooting-range-addresses": "pnpm dlx tsx src/features/ammo-ledger/range-seed/resolve-range-addresses/resolve-range-addresses.ts",
    "fill:shooting-range-partial-addresses": "pnpm dlx tsx src/features/ammo-ledger/range-seed/resolve-range-addresses/fill-partial-addresses.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "better-auth": "^1.6.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@serwist/turbopack": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "pdf-parse": "^1.1.1",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
