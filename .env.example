# 参照用。実値は Doppler（プロジェクト utopi-a-dev）に保存する。
# ローカル: pnpm env:setup && pnpm dev

DATABASE_URL=""

BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# メール送信（Resend）。未設定時は dev でターミナルにリンク出力
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
AUTH_REQUIRE_EMAIL_VERIFICATION="false"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 新規登録を許可するか（false / 0 で無効）
AUTH_ALLOW_SIGNUP="true"

# オーナー限定機能用（カンマ区切り）。未設定なら制限なし
OWNER_EMAILS=""
